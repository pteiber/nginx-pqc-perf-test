# Managed by Ansible ({{ ansible_managed }}) - do not edit directly.
# Traffic-mix nginx-classic target. The only semantic difference from
# nginx-pqc.conf.j2 is the ssl_conf_command Groups line below;
# everything else (session resumption, payload serving, tuning) is
# identical between the two so the TLS key-exchange group stays the one
# independent variable.
#
# Unlike the handshake-only fleet target, this config ENABLES TLS session
# resumption (session cache + stateless tickets) so the client's
# resume-pct knob has an effect, and serves a large payload.bin for the
# random-sized Range requests. Listens on {{ nginx_classic_port }} (both
# instances share one host), has an explicit pid file (two instances would
# otherwise collide on nginx's compiled-in default pid path), and uses
# absolute paths under {{ deploy_root }}. Binds all interfaces so the
# client can reach it over the intra-VPC network.

pid /run/nginx-classic.pid;
worker_processes auto;

events {
    # Raised well above the fleet target's 1024: the traffic-mix client
    # holds a warm keep-alive pool plus churned handshake connections.
    worker_connections 8192;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    access_log off;
    error_log /var/log/nginx/nginx-classic-error.log;

    # Keep-alive connections should stay warm for the whole run so the
    # request subsystem measures serving, not repeated handshakes.
    keepalive_timeout 300s;
    keepalive_requests 1000000;
    sendfile on;

    server {
        listen {{ nginx_classic_port }} ssl;
        server_name localhost;

        ssl_certificate     {{ deploy_root }}/certs/server.crt;
        ssl_certificate_key {{ deploy_root }}/certs/server.key;

        # TLS 1.3 only, classical ECDHE key exchange only (no PQC group
        # offered). This is the baseline this benchmark compares against
        # nginx-pqc.conf.j2, which offers X25519MLKEM768 instead; this
        # Groups line is the only thing that differs between the two.
        ssl_protocols TLSv1.3;
        ssl_conf_command Groups X25519;

        # Resumption ENABLED (the fleet target has both off). Stateless
        # tickets let any worker process resume, which is what makes the
        # client's resume-pct reproducible across nginx's worker_processes.
        ssl_session_cache shared:SSL:50m;
        ssl_session_tickets on;

        root {{ deploy_root }}/html;

        location = /small {
            alias {{ deploy_root }}/html/small.html;
        }

        # Random-sized responses: the client sends Range: bytes=0-(n-1)
        # against this file, so nginx replies 206 with exactly n bytes.
        location = /payload.bin {
            alias {{ deploy_root }}/html/payload.bin;
        }
    }
}
