# Managed by Ansible ({{ ansible_managed }}) - do not edit directly.
# Mirrors nginx/pqc/nginx.conf in the repo root (container variant); the
# only semantic difference from nginx-classic.conf.j2 is the
# ssl_conf_command Groups line below. Adapted for a native systemd
# deployment: listens on {{ nginx_pqc_port }} instead of 443 (both
# instances share one host), has an explicit pid file (two instances
# would otherwise collide on nginx's compiled-in default pid path), and
# uses absolute paths under {{ deploy_root }} instead of container paths.

pid /run/nginx-pqc.pid;
worker_processes auto;

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    access_log off;
    error_log /var/log/nginx/nginx-pqc-error.log;

    server {
        listen {{ nginx_pqc_port }} ssl;
        server_name localhost;

        ssl_certificate     {{ deploy_root }}/certs/server.crt;
        ssl_certificate_key {{ deploy_root }}/certs/server.key;

        # TLS 1.3 only. Offer the hybrid post-quantum KEM X25519MLKEM768
        # first, with classical X25519 as fallback. This is the only line
        # that differs from nginx-classic.conf.j2.
        ssl_protocols TLSv1.3;
        ssl_conf_command Groups X25519MLKEM768:X25519;

        ssl_session_cache off;
        ssl_session_tickets off;

        root {{ deploy_root }}/html;

        location = /small {
            alias {{ deploy_root }}/html/small.html;
        }
    }
}
